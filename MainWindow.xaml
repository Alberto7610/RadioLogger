<Window x:Class="RadioLogger.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:RadioLogger.ViewModels"
        xmlns:local="clr-namespace:RadioLogger"
        mc:Ignorable="d"
        Title="Gemini Radio Logger 2026" Height="650" Width="850"
        Background="#121212" Foreground="White">
    
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- Converters are now Global in App.xaml -->
        
        <!-- ON/AIR Toggle Style -->
        <Style x:Key="OnAirButtonStyle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <!-- Button Housing (The hole in the console) -->
                            <Border Width="94" Height="37" CornerRadius="5" Background="#111" BorderBrush="#444" BorderThickness="0,0,1,1">
                                <Border.Effect><BlurEffect Radius="2"/></Border.Effect>
                            </Border>
                            
                            <!-- The Physical Button -->
                            <Border x:Name="BtnBody" Width="90" Height="35" CornerRadius="4" BorderThickness="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#333" Offset="0"/>
                                        <GradientStop Color="#222" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#555" Offset="0"/>
                                        <GradientStop Color="#111" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                
                                <Grid>
                                    <!-- Text Label (Off State) -->
                                    <TextBlock x:Name="BtnText" Text="OFF" Foreground="#555" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center" 
                                               FontWeight="Black" FontSize="11" FontFamily="Consolas">
                                        <TextBlock.Effect>
                                            <DropShadowEffect Color="Black" BlurRadius="1" ShadowDepth="1" Direction="270" Opacity="0.8"/>
                                        </TextBlock.Effect>
                                    </TextBlock>
                                    
                                    <!-- Inner Glow (Hidden by default) -->
                                    <Border x:Name="InnerGlow" CornerRadius="3" Opacity="0" Background="#CC3300">
                                        <Border.Effect><BlurEffect Radius="10"/></Border.Effect>
                                    </Border>
                                </Grid>
                                
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="3" Direction="270"/>
                                </Border.Effect>
                                <Border.RenderTransform>
                                    <TranslateTransform Y="0"/>
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                        
                        <ControlTemplate.Triggers>
                            <!-- PRESSED STATE (Physical Push) -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBody" Property="RenderTransform">
                                    <Setter.Value><TranslateTransform Y="2"/></Setter.Value>
                                </Setter>
                                <Setter TargetName="BtnBody" Property="Effect">
                                    <Setter.Value><DropShadowEffect Color="Black" BlurRadius="2" ShadowDepth="1" Direction="270"/></Setter.Value>
                                </Setter>
                            </Trigger>
                            
                            <!-- CHECKED STATE (Light Up) -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="BtnBody" Property="Background">
                                    <Setter.Value>
                                        <RadialGradientBrush GradientOrigin="0.5,0.5">
                                            <GradientStop Color="#FF5722" Offset="0"/>
                                            <GradientStop Color="#BF360C" Offset="1"/>
                                        </RadialGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="BtnBody" Property="BorderBrush" Value="#FF7043"/>
                                <Setter TargetName="InnerGlow" Property="Opacity" Value="0.6"/>
                                <Setter TargetName="BtnText" Property="Text" Value="ON AIR"/>
                                <Setter TargetName="BtnText" Property="Foreground" Value="White"/>
                                <Setter TargetName="BtnText" Property="Effect">
                                    <Setter.Value><DropShadowEffect Color="#800000" BlurRadius="2" ShadowDepth="0"/></Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- STREAM Toggle Style -->
        <Style x:Key="StreamButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <!-- Button Housing -->
                            <Border Width="94" Height="32" CornerRadius="3" Background="#050505" BorderBrush="#333" BorderThickness="0,0,1,1">
                                <Border.Effect><BlurEffect Radius="1"/></Border.Effect>
                            </Border>
                            
                            <!-- The Physical Button -->
                            <Border x:Name="BtnBody" Width="90" Height="30" CornerRadius="2" BorderThickness="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#222" Offset="0"/>
                                        <GradientStop Color="#111" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#444" Offset="0"/>
                                        <GradientStop Color="#111" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                
                                <Grid>
                                    <TextBlock x:Name="BtnText" Text="STREAM" Foreground="#444" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center" 
                                               FontWeight="Bold" FontSize="10" FontFamily="Consolas"/>
                                    
                                    <!-- Inner Glow -->
                                    <Border x:Name="InnerGlow" CornerRadius="1" Opacity="0" Background="#00FF00">
                                        <Border.Effect><BlurEffect Radius="8"/></Border.Effect>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                        
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBody" Property="RenderTransform">
                                    <Setter.Value><TranslateTransform Y="1"/></Setter.Value>
                                </Setter>
                            </Trigger>
                            
                            <!-- State 2: Reconnecting (Project Mandate: Yellow/Black Flashing) -->
                            <!-- OLD STYLE BACKUP (Vibrant Orange):
                                 Background: RadialGradient #FF7043 to #BF360C
                                 BorderBrush: #FFAB91, Text: White
                            -->
                            <DataTrigger Binding="{Binding IsReconnecting}" Value="True">
                                <Setter TargetName="BtnBody" Property="Background" Value="#FFD600"/>
                                <Setter TargetName="BtnBody" Property="BorderBrush" Value="#000000"/>
                                <Setter TargetName="BtnText" Property="Text" Value="RECONECTANDO..."/>
                                <Setter TargetName="BtnText" Property="FontSize" Value="9"/>
                                <Setter TargetName="BtnText" Property="FontWeight" Value="Bold"/>
                                <Setter TargetName="BtnText" Property="Foreground" Value="Black"/>
                                <Setter TargetName="BtnText" Property="Effect" Value="{x:Null}"/> <!-- Remove shadow for readability on yellow -->
                                
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard Name="PulseGlow">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="BtnBody"
                                                             Storyboard.TargetProperty="Opacity"
                                                             From="1.0" To="0.4" Duration="0:0:0.5"
                                                             AutoReverse="True" RepeatBehavior="Forever"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <RemoveStoryboard BeginStoryboardName="PulseGlow"/>
                                </DataTrigger.ExitActions>
                            </DataTrigger>

                            <!-- STATE: ONLINE (Only if NOT Reconnecting) -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsStreaming}" Value="True"/>
                                    <Condition Binding="{Binding IsReconnecting}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="BtnBody" Property="Background">
                                    <Setter.Value>
                                        <RadialGradientBrush GradientOrigin="0.5,0.5">
                                            <GradientStop Color="#00C853" Offset="0"/>
                                            <GradientStop Color="#007E33" Offset="1"/>
                                        </RadialGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="BtnBody" Property="BorderBrush" Value="#00E676"/>
                                <Setter TargetName="InnerGlow" Property="Opacity" Value="0.5"/>
                                <Setter TargetName="InnerGlow" Property="Background" Value="#00FF00"/>
                                <Setter TargetName="BtnText" Property="Text" Value="ON LINE"/>
                                <Setter TargetName="BtnText" Property="FontSize" Value="10"/>
                                <Setter TargetName="BtnText" Property="Foreground" Value="White"/>
                                <Setter TargetName="BtnText" Property="Effect">
                                    <Setter.Value><DropShadowEffect Color="#00FF00" BlurRadius="4" ShadowDepth="0"/></Setter.Value>
                                </Setter>
                            </MultiDataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
        </Style>

        <!-- ANIMATED HEADER BUTTON STYLE -->
        <Style x:Key="AnimatedHeaderButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#AAA"/> <!-- Default Icon Color -->
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Width="42" Height="42" CornerRadius="21"
                                Background="#222" BorderBrush="#444" BorderThickness="1.5">
                            <Border.Effect>
                                <DropShadowEffect x:Name="OuterGlow" Color="Transparent" BlurRadius="0" ShadowDepth="0"/>
                            </Border.Effect>
                            
                            <ContentPresenter x:Name="content" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ContentPresenter.Effect>
                                    <DropShadowEffect x:Name="TextGlow" Color="Transparent" BlurRadius="0" ShadowDepth="0"/>
                                </ContentPresenter.Effect>
                            </ContentPresenter>
                        </Border>
                        
                        <ControlTemplate.Triggers>
                            <!-- Hover Animation (Grow + Glow Everything) -->
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <!-- Scale -->
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.15" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.15" Duration="0:0:0.2"/>
                                        
                                        <!-- Border Glow -->
                                        <ColorAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#00AABB" Duration="0:0:0.2"/>
                                        <ColorAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#2A2A2A" Duration="0:0:0.2"/>
                                        
                                        <!-- Icon Color & Glow -->
                                        <ColorAnimation Storyboard.TargetProperty="(Button.Foreground).(SolidColorBrush.Color)" To="White" Duration="0:0:0.2"/>
                                        <ColorAnimation Storyboard.TargetName="content" Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Color)" To="#00FFFF" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="content" Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)" To="12" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            
                            <!-- Leave Animation -->
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.15"/>
                                        <ColorAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#444" Duration="0:0:0.2"/>
                                        <ColorAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#222" Duration="0:0:0.2"/>
                                        
                                        <!-- Icon Reset -->
                                        <ColorAnimation Storyboard.TargetProperty="(Button.Foreground).(SolidColorBrush.Color)" To="#AAA" Duration="0:0:0.2"/>
                                        <ColorAnimation Storyboard.TargetName="content" Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Color)" To="Transparent" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="content" Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)" To="0" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value><ScaleTransform ScaleX="0.95" ScaleY="0.95"/></Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="*"/>    <!-- List -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="0,0,0,15" BorderBrush="#333" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border Background="#00AABB" Width="5" Height="30" Margin="0,0,10,0">
                        <Border.Effect><DropShadowEffect Color="#00AABB" BlurRadius="10"/></Border.Effect>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="{Binding StationName}" FontSize="26" FontWeight="ExtraBold" Foreground="#00AABB">
                            <TextBlock.Effect><DropShadowEffect Color="Black" BlurRadius="2" ShadowDepth="2"/></TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="CONSOLA DE TESTIGO PROFESIONAL 24/7" FontSize="10" Foreground="#666" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>

                <!-- Right Header Panel: Clock & Config -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    
                    <!-- Digital Info Panel -->
                    <Border Background="Black" BorderBrush="#444" BorderThickness="2" CornerRadius="4" Padding="10,5" Margin="0,0,15,0">
                        <StackPanel Orientation="Horizontal">
                            <!-- Rec Timer -->
                            <StackPanel Margin="0,0,15,0" VerticalAlignment="Center">
                                <TextBlock Text="GRABANDO" FontSize="8" Foreground="#555" HorizontalAlignment="Right"/>
                                <TextBlock Text="{Binding CurrentRecDuration, TargetNullValue='0d 00h 00m 00s'}" Foreground="#CC3300" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/>
                            </StackPanel>
                            
                            <Rectangle Fill="#333" Width="1" Margin="0,0,15,0"/>

                            <!-- MASTER CLOCK -->
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="HORA ACTUAL" FontSize="8" Foreground="#555" HorizontalAlignment="Right"/>
                                <TextBlock Text="{Binding CurrentTime}" Foreground="#00FFCC" FontFamily="Consolas" FontSize="20" FontWeight="Bold">
                                    <TextBlock.Effect><DropShadowEffect Color="#00FFCC" BlurRadius="8" ShadowDepth="0" Opacity="0.6"/></TextBlock.Effect>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Player Button -->
                    <Button Command="{Binding OpenPlayerCommand}" Cursor="Hand" ToolTip="Auditor de Testigos" Margin="0,0,15,0"
                            Style="{StaticResource AnimatedHeaderButtonStyle}">
                        <TextBlock Text="▶" FontFamily="Segoe UI Symbol" FontSize="18" Foreground="#AAA" Margin="2,0,0,0"/>
                    </Button>

                    <!-- Settings Button -->
                    <Button Command="{Binding OpenSettingsCommand}" Cursor="Hand" ToolTip="Configuración"
                            Style="{StaticResource AnimatedHeaderButtonStyle}">
                        <TextBlock Text="⚙" FontFamily="Segoe UI Symbol" FontSize="22" Foreground="#AAA"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Device List -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,15">
            <ItemsControl ItemsSource="{Binding InputDevices}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Rack Mount Chassis -->
                        <Border Margin="0,0,0,15" CornerRadius="4" BorderBrush="#111" BorderThickness="1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#2A2A2A" Offset="0"/>
                                    <GradientStop Color="#1F1F1F" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="5" Opacity="0.5"/>
                            </Border.Effect>
                            
                                                        <Border x:Name="ModuleBorder" CornerRadius="4" BorderThickness="2" BorderBrush="Transparent">
                                                            <Grid Margin="10">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="115"/>  <!-- Control ON/OFF -->
                                                                    <ColumnDefinition Width="1"/>   <!-- Separator -->
                                                                    <ColumnDefinition Width="80"/>  <!-- Fader Section -->
                                                                    <ColumnDefinition Width="1"/>   <!-- Separator -->
                                                                    <ColumnDefinition Width="*"/>   <!-- Meter Section -->
                                                                </Grid.ColumnDefinitions>
                            
                                                                <!-- Screws (Decoration) -->
                                                                <Grid Grid.ColumnSpan="5" IsHitTestVisible="False">
                                                                    <Ellipse Width="6" Height="6" Fill="#111" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="2,2,0,0"/>
                                                                    <Ellipse Width="6" Height="6" Fill="#111" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,2,2,0"/>
                                                                    <Ellipse Width="6" Height="6" Fill="#111" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="2,0,0,2"/>
                                                                    <Ellipse Width="6" Height="6" Fill="#111" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,2,2"/>
                                                                    
                                                                    <!-- Screw Heads -->
                                                                    <Ellipse Width="4" Height="4" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="3,3,0,0">
                                                                        <Ellipse.Fill><RadialGradientBrush><GradientStop Color="#555" Offset="0"/><GradientStop Color="#222" Offset="1"/></RadialGradientBrush></Ellipse.Fill>
                                                                    </Ellipse>
                                                                    <Ellipse Width="4" Height="4" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,3,3,0">
                                                                        <Ellipse.Fill><RadialGradientBrush><GradientStop Color="#555" Offset="0"/><GradientStop Color="#222" Offset="1"/></RadialGradientBrush></Ellipse.Fill>
                                                                    </Ellipse>
                                                                    <Ellipse Width="4" Height="4" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="3,0,0,3">
                                                                        <Ellipse.Fill><RadialGradientBrush><GradientStop Color="#555" Offset="0"/><GradientStop Color="#222" Offset="1"/></RadialGradientBrush></Ellipse.Fill>
                                                                    </Ellipse>
                                                                    <Ellipse Width="4" Height="4" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,3,3">
                                                                        <Ellipse.Fill><RadialGradientBrush><GradientStop Color="#555" Offset="0"/><GradientStop Color="#222" Offset="1"/></RadialGradientBrush></Ellipse.Fill>
                                                                    </Ellipse>
                                                                </Grid>
                            
                                                                <!-- SECTION 1: ON/AIR -->
                                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                                    <CheckBox IsChecked="{Binding IsSelected}" 
                                                                              Style="{StaticResource OnAirButtonStyle}"
                                                                              Command="{Binding DataContext.ToggleDeviceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                              CommandParameter="{Binding}"
                                                                              HorizontalAlignment="Center"/>
                                                                    <TextBlock Text="{Binding StationName}" Foreground="#00AABB" FontSize="10" TextWrapping="Wrap" 
                                                                               TextAlignment="Center" Margin="0,5,0,0" FontWeight="Bold" MaxHeight="40">
                                                                        <TextBlock.Effect><DropShadowEffect Color="Black" BlurRadius="1" ShadowDepth="1"/></TextBlock.Effect>
                                                                    </TextBlock>
                                                                    
                                                                                                            <!-- Individual Channel Timer -->
                                                                                                            <Border Background="#050505" CornerRadius="2" Padding="4,1" Margin="0,3,0,3" BorderBrush="#333" BorderThickness="1">
                                                                                                                <TextBlock Text="{Binding RecordingDuration}" Foreground="#CC3300" 
                                                                                                                           FontSize="11" FontFamily="Consolas" FontWeight="Bold" 
                                                                                                                           HorizontalAlignment="Center"/>
                                                                                                            </Border>
                                                                    
                                                                                                                                                                                        <!-- STREAM Button -->
                                                                                                                                                                                        <Button Style="{StaticResource StreamButtonStyle}" 
                                                                                                                                                                                                Command="{Binding DataContext.ToggleStreamingCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                                                                                                                                CommandParameter="{Binding}"
                                                                                                                                                                                                HorizontalAlignment="Center" Margin="0,2,0,0"/>                                                                    
                                                                                                            <TextBlock Text="{Binding Device.Name}" Foreground="#444" FontSize="7" TextAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,5,0,0"/>                                                                </StackPanel>
                                    <!-- Etched Groove Separator -->
                                    <Border Grid.Column="1" Background="#111" Width="1" Margin="5,0">
                                        <Border.Effect><DropShadowEffect Color="White" ShadowDepth="1" BlurRadius="0" Opacity="0.1" Direction="180"/></Border.Effect>
                                    </Border>

                                    <!-- SECTION 2: PROFESSIONAL FADER -->
                                    <Grid Grid.Column="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Scale -->
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,0">
                                            <TextBlock Text="+6" FontSize="8" Foreground="#888" HorizontalAlignment="Right"/>
                                            <TextBlock Text="0" FontSize="10" Foreground="#EEE" FontWeight="Bold" Margin="0,16" HorizontalAlignment="Right"/>
                                            <TextBlock Text="∞" FontSize="11" Foreground="#888" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                        
                                        <!-- Fader -->
                                        <Slider Grid.Column="1" Orientation="Vertical" Minimum="0" Maximum="150" 
                                                Value="{Binding InputVolume}" Height="100" VerticalAlignment="Center">
                                            <Slider.Resources>
                                                <Style TargetType="Slider">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Slider">
                                                                <Grid>
                                                                    <!-- The Rail Slot -->
                                                                    <Border Background="#050505" Width="6" CornerRadius="3" VerticalAlignment="Stretch" HorizontalAlignment="Center" BorderBrush="#333" BorderThickness="1">
                                                                        <Border.Effect><DropShadowEffect Color="White" ShadowDepth="1" BlurRadius="0" Opacity="0.1"/></Border.Effect>
                                                                    </Border>
                                                                    
                                                                    <!-- 0dB Marker -->
                                                                    <Rectangle Fill="#555" Height="1" Width="12" VerticalAlignment="Top" Margin="0,33,0,0" Opacity="0.5"/>

                                                                    <Track x:Name="PART_Track">
                                                                        <Track.Thumb>
                                                                            <Thumb>
                                                                                <Thumb.Template>
                                                                                    <ControlTemplate TargetType="Thumb">
                                                                                        <!-- 3D FADER CAP -->
                                                                                        <Grid Width="26" Height="42">
                                                                                            <Grid.Effect><DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="3" Opacity="0.6"/></Grid.Effect>
                                                                                            <Border BorderBrush="#111" BorderThickness="1" CornerRadius="2">
                                                                                                <Border.Background>
                                                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                                                        <GradientStop Color="#BBB" Offset="0"/>
                                                                                                        <GradientStop Color="#EEE" Offset="0.2"/>
                                                                                                        <GradientStop Color="#CCC" Offset="0.5"/>
                                                                                                        <GradientStop Color="#999" Offset="0.9"/>
                                                                                                        <GradientStop Color="#777" Offset="1.0"/>
                                                                                                    </LinearGradientBrush>
                                                                                                </Border.Background>
                                                                                                <Grid Margin="1">
                                                                                                    <!-- Concave Shadow -->
                                                                                                    <Border Background="Transparent" BorderBrush="#80000000" BorderThickness="1,0,1,0" Margin="4,0" Opacity="0.2"/>
                                                                                                    <!-- Ridges -->
                                                                                                    <StackPanel VerticalAlignment="Center" Margin="0,5">
                                                                                                        <Border Height="2" Margin="3,1" Background="#888" BorderBrush="#FFF" BorderThickness="0,1,0,0"/>
                                                                                                        <Border Height="2" Margin="3,1" Background="#888" BorderBrush="#FFF" BorderThickness="0,1,0,0"/>
                                                                                                        <Border Height="2" Margin="3,1" Background="#888" BorderBrush="#FFF" BorderThickness="0,1,0,0"/>
                                                                                                    </StackPanel>
                                                                                                    <!-- Indicator Line -->
                                                                                                    <Rectangle Fill="#D00" Height="2" Width="20" VerticalAlignment="Center">
                                                                                                        <Rectangle.Effect><DropShadowEffect Color="#F00" BlurRadius="2" ShadowDepth="0"/></Rectangle.Effect>
                                                                                                    </Rectangle>
                                                                                                </Grid>
                                                                                            </Border>
                                                                                        </Grid>
                                                                                    </ControlTemplate>
                                                                                </Thumb.Template>
                                                                            </Thumb>
                                                                        </Track.Thumb>
                                                                    </Track>
                                                                </Grid>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Slider.Resources>
                                        </Slider>
                                    </Grid>

                                    <!-- Etched Groove -->
                                    <Border Grid.Column="3" Background="#111" Width="1" Margin="5,0">
                                        <Border.Effect><DropShadowEffect Color="White" ShadowDepth="1" BlurRadius="0" Opacity="0.1" Direction="180"/></Border.Effect>
                                    </Border>

                                    <!-- SECTION 3: METERS -->
                                    <Grid Grid.Column="4" Margin="5,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="30"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Glass Overlay Container -->
                                        <Grid Grid.Column="0">
                                            <StackPanel VerticalAlignment="Center">
                                                <!-- dB Scale Labels -->
                                                <Grid Margin="15,0,0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="66*"/>
                                                        <ColumnDefinition Width="24*"/>
                                                        <ColumnDefinition Width="10*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="-60" FontSize="8" Foreground="#555" HorizontalAlignment="Left"/>
                                                    <TextBlock Grid.Column="0" Text="-20" FontSize="8" Foreground="#666" HorizontalAlignment="Right" Margin="0,0,-5,0"/>
                                                    <TextBlock Grid.Column="1" Text="-6" FontSize="8" Foreground="#666" HorizontalAlignment="Right" Margin="0,0,-3,0"/>
                                                    <TextBlock Grid.Column="2" Text="0" FontSize="8" Foreground="#AAA" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                </Grid>

                                                <!-- L Meter -->
                                                <Grid Margin="0,2" x:Name="LGrid">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="15"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="L" FontSize="9" Foreground="#666" VerticalAlignment="Center" FontWeight="Bold"/>
                                                    <Grid Grid.Column="1" Height="12" x:Name="LTrack">
                                                        <Border Background="#050505" CornerRadius="1"/>
                                                        <Grid Margin="1" Opacity="0.2">
                                                            <Grid.Background>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                    <GradientStop Color="#00C853" Offset="0.0"/>
                                                                    <GradientStop Color="#FFEA00" Offset="0.8"/>
                                                                    <GradientStop Color="#D50000" Offset="1.0"/>
                                                                </LinearGradientBrush>
                                                            </Grid.Background>
                                                        </Grid>
                                                        <Border HorizontalAlignment="Left" ClipToBounds="True" Margin="1">
                                                            <Border.Width><MultiBinding Converter="{StaticResource PeakConverter}">
                                                                <Binding Path="LeftLevel"/><Binding ElementName="LTrack" Path="ActualWidth"/>
                                                            </MultiBinding></Border.Width>
                                                            <Grid Width="{Binding ActualWidth, ElementName=LTrack}">
                                                                <Grid.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                    <GradientStop Color="#00C853" Offset="0.0"/>
                                                                    <GradientStop Color="#FFEA00" Offset="0.8"/>
                                                                    <GradientStop Color="#D50000" Offset="1.0"/>
                                                                </LinearGradientBrush></Grid.Background>
                                                            </Grid>
                                                        </Border>
                                                        <Canvas Margin="1"><Rectangle Width="2" Height="12" 
                                                                       Fill="{Binding LeftPeak, Converter={StaticResource PeakColorConverter}}" 
                                                                       Opacity="1">
                                                            <Canvas.Left><MultiBinding Converter="{StaticResource PeakConverter}">
                                                                <Binding Path="LeftPeak"/><Binding ElementName="LTrack" Path="ActualWidth"/>
                                                            </MultiBinding></Canvas.Left>
                                                        </Rectangle></Canvas>
                                                        
                                                        <!-- Glass Reflection Overlay -->
                                                        <Border Background="White" Opacity="0.05" VerticalAlignment="Top" Height="6" CornerRadius="1"/>
                                                    </Grid>
                                                </Grid>
                                                
                                                <!-- R Meter -->
                                                <Grid Margin="0,2" x:Name="RGrid">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="15"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="R" FontSize="9" Foreground="#666" VerticalAlignment="Center" FontWeight="Bold"/>
                                                    <Grid Grid.Column="1" Height="12" x:Name="RTrack">
                                                        <Border Background="#050505" CornerRadius="1"/>
                                                        <Grid Margin="1" Opacity="0.2">
                                                            <Grid.Background>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                    <GradientStop Color="#00C853" Offset="0.0"/>
                                                                    <GradientStop Color="#FFEA00" Offset="0.8"/>
                                                                    <GradientStop Color="#D50000" Offset="1.0"/>
                                                                </LinearGradientBrush>
                                                            </Grid.Background>
                                                        </Grid>
                                                        <Border HorizontalAlignment="Left" ClipToBounds="True" Margin="1">
                                                            <Border.Width><MultiBinding Converter="{StaticResource PeakConverter}">
                                                                <Binding Path="RightLevel"/><Binding ElementName="RTrack" Path="ActualWidth"/>
                                                            </MultiBinding></Border.Width>
                                                            <Grid Width="{Binding ActualWidth, ElementName=RTrack}">
                                                                <Grid.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                    <GradientStop Color="#00C853" Offset="0.0"/>
                                                                    <GradientStop Color="#FFEA00" Offset="0.8"/>
                                                                    <GradientStop Color="#D50000" Offset="1.0"/>
                                                                </LinearGradientBrush></Grid.Background>
                                                            </Grid>
                                                        </Border>
                                                        <Canvas Margin="1"><Rectangle Width="2" Height="12" 
                                                                       Fill="{Binding RightPeak, Converter={StaticResource PeakColorConverter}}" 
                                                                       Opacity="1">
                                                            <Canvas.Left><MultiBinding Converter="{StaticResource PeakConverter}">
                                                                <Binding Path="RightPeak"/><Binding ElementName="RTrack" Path="ActualWidth"/>
                                                            </MultiBinding></Canvas.Left>
                                                        </Rectangle></Canvas>
                                                        <!-- Glass Reflection Overlay -->
                                                        <Border Background="White" Opacity="0.05" VerticalAlignment="Top" Height="6" CornerRadius="1"/>
                                                    </Grid>
                                                </Grid>
                                                
                                                <TextBlock Text="FALLA DE AUDIO" Foreground="#F44" FontWeight="Bold" FontSize="9" HorizontalAlignment="Center" Margin="0,4,0,0"
                                                           Visibility="{Binding IsSilenceDetected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock.Effect><DropShadowEffect Color="Red" BlurRadius="5" ShadowDepth="0"/></TextBlock.Effect>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>

                                        <!-- PK LED -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="PK" FontSize="8" Foreground="#444" Margin="0,0,0,2" HorizontalAlignment="Center"/>
                                            <Border Width="12" Height="12" CornerRadius="6" BorderBrush="#000" BorderThickness="1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#220000"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsClipping}" Value="True">
                                                                <Setter Property="Background" Value="#F00"/>
                                                                <Setter Property="Effect"><Setter.Value><DropShadowEffect Color="Red" BlurRadius="8" ShadowDepth="0"/></Setter.Value></Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <!-- Glass shine on LED -->
                                                <Ellipse Width="6" Height="4" Margin="0,1,0,0" VerticalAlignment="Top" Fill="White" Opacity="0.3"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSilenceDetected}" Value="True">
                                <Setter TargetName="ModuleBorder" Property="BorderBrush" Value="#F00"/>
                                <Setter TargetName="ModuleBorder" Property="Background" Value="#2A0000"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer -->
        <StatusBar Grid.Row="2" Background="#007ACC" Foreground="White" Padding="5">
            <StatusBarItem><TextBlock Text="{Binding StatusMessage}" FontSize="11"/></StatusBarItem>
            <Separator Background="#44FFFFFF"/>
            <StatusBarItem HorizontalAlignment="Right"><TextBlock Text="{Binding StorageInfo}" FontSize="11" FontWeight="Bold"/></StatusBarItem>
        </StatusBar>
    </Grid>
</Window>