@using RadioLogger.Shared.Models

@{
    var isLive = (DateTime.UtcNow - Update.Timestamp).TotalSeconds < 15;
    var isActive = isLive && Update.IsRecording;
    var isDisconnected = !isLive;
}

<div class="sc @(isActive ? "online" : "offline") @(isDisconnected ? "disconnected" : "") @(Update.IsSilence && isLive ? "silence" : "")">
    @if (!Update.IsAuthorized)
    {
        <div class="authorized-overlay">
            <span class="lock-icon">🔒</span>
            <span class="lock-text">PENDIENTE</span>
        </div>
    }

    <div class="sc-top">
        <div class="sc-info">
            <div class="sc-name">@Update.StationName</div>
            <div class="sc-srv">@Update.MachineId</div>
        </div>
        <div class="badges">
            @if (Update.IsRecordingEnabled)
            {
                <div class="bdg @(Update.IsRecording ? "on" : "off")">@(Update.IsRecording ? "ON AIR" : "OFF AIR")</div>
            }
            else
            {
                <div class="bdg off" title="Grabación deshabilitada en configuración">NO REC</div>
            }
            <div class="rec-clock @(Update.IsRecording ? "" : "inactive")">@GetDuration()</div>
            <div class="bdg @(Update.IsStreaming ? "on" : "off")">STREAM</div>
        </div>
    </div>

    <!-- Vúmetros con Peak Hold y Clipping -->
    <div class="vu-container">
        <div class="vu-row">
            <div class="vu-ch">L</div>
            <div class="vu-bar-wrapper">
                <div class="vu-mask" style="width: @(SafePct(1 - Update.LeftLevel))%;"></div>
                <div class="vu-peak @(GetPeakClass(Update.LeftPeak))" style="left: @(SafePct(Update.LeftPeak))%;"></div>
            </div>
            <div class="vu-clip-led @(IsClipping(Update.LeftPeak) ? "clip-on" : "")"></div>
        </div>
        <div class="vu-row">
            <div class="vu-ch">R</div>
            <div class="vu-bar-wrapper">
                <div class="vu-mask" style="width: @(SafePct(1 - Update.RightLevel))%;"></div>
                <div class="vu-peak @(GetPeakClass(Update.RightPeak))" style="left: @(SafePct(Update.RightPeak))%;"></div>
            </div>
            <div class="vu-clip-led @(IsClipping(Update.RightPeak) ? "clip-on" : "")"></div>
        </div>
    </div>

    <div class="sc-foot">
        <div class="sc-time">@Update.Timestamp.ToLocalTime().ToString("HH:mm:ss")</div>
        @if (isDisconnected)
        {
            <div class="sc-status-led disconnected-led">
                <div class="led-light red"></div>
                <span class="led-label">DESCONECTADA</span>
            </div>
        }
        else if (Update.IsSilence)
        {
            <div class="bdg sil">SILENCIO</div>
        }
        else
        {
            <div class="sc-status-led">
                <div class="led-light green"></div>
                <span class="led-label on">EN LÍNEA</span>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public StationStatusUpdate Update { get; set; } = new();

    private string GetPeakClass(double peak)
    {
        double pct = Math.Clamp(peak, 0, 1) * 100;
        if (pct >= 95) return "pk-r";
        if (pct >= 80) return "pk-o";
        if (pct >= 50) return "pk-y";
        return "pk-g";
    }

    private bool IsClipping(double peak) => peak >= 0.98;

    private string SafePct(double val) => FormattableString.Invariant($"{Math.Clamp(val * 100, 0, 100):F1}");

    private string GetDuration()
    {
        if (Update.RecordingStartTime == null) return "00d 00h 00m 00s";
        var diff = DateTime.UtcNow - Update.RecordingStartTime.Value;
        return $"{diff.Days:D2}d {diff.Hours:D2}h {diff.Minutes:D2}m {diff.Seconds:D2}s";
    }
}
