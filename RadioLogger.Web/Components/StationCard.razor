@using RadioLogger.Shared.Models

<div class="station-card @(Update.IsSilence ? "silence-alert" : "")">
    <div class="station-header">
        <span class="status-dot @(Update.IsRecording ? "dot-on" : "dot-off")"></span>
        <span class="station-name">@Update.StationName</span>
    </div>

    <div class="meters-container">
        <!-- L Meter -->
        <div class="meter-row">
            <span class="meter-label">L</span>
            <div class="meter-track">
                <!-- La barra de color es fija, solo se 'descubre' con clip-path -->
                <div class="meter-fill" style="clip-path: inset(0 @($"{100 - (Update.LeftLevel * 100):0.##}%") 0 0)"></div>
                <div class="meter-shine"></div>
                <div class="peak-marker" style="left: @($"{Update.LeftPeak * 100:0.##}%")"></div>
                <div class="meter-grid"></div>
            </div>
        </div>
        <!-- R Meter -->
        <div class="meter-row">
            <span class="meter-label">R</span>
            <div class="meter-track">
                <div class="meter-fill" style="clip-path: inset(0 @($"{100 - (Update.RightLevel * 100):0.##}%") 0 0)"></div>
                <div class="meter-shine"></div>
                <div class="peak-marker" style="left: @($"{Update.RightPeak * 100:0.##}%")"></div>
                <div class="meter-grid"></div>
            </div>
        </div>
    </div>

    <div class="station-footer">
        <div class="footer-left">
            <span class="status-badge @(Update.IsRecording ? "badge-online" : "badge-offline")">
                @(Update.IsRecording ? "ON AIR" : "OFF AIR")
            </span>
            
            @if (Update.IsStreaming)
            {
                <span class="stream-tag">WEB STREAM</span>
            }
        </div>
        
        <div class="footer-right">
            @if (Update.IsStreaming && !string.IsNullOrEmpty(Update.StreamUrl))
            {
                <button class="btn-listen @(IsPlaying ? "active" : "")" @onclick="TogglePlay">
                    @(IsPlaying ? "■" : "▶")
                </button>
            }
            <span class="timestamp">@Update.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
        </div>
    </div>

    @if (IsPlaying && !string.IsNullOrEmpty(Update.StreamUrl))
    {
        <div class="mini-player">
            <audio autoplay controls>
                <source src="@Update.StreamUrl" type="audio/mpeg">
            </audio>
        </div>
    }
</div>

@code {
    [Parameter] public StationStatusUpdate Update { get; set; } = new();
    private bool IsPlaying = false;
    private void TogglePlay() => IsPlaying = !IsPlaying;
}