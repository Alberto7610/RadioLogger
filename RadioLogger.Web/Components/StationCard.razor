@using RadioLogger.Shared.Models

<div class="station-card @(Update.IsSilence ? "silence-alert" : "")">
    <div class="station-header">
        <div class="header-main">
            <span class="station-name">@Update.StationName</span>
            <span class="machine-id">SERVIDOR: @Update.MachineId</span>
        </div>
        <div class="status-indicators">
            <!-- Badge ON AIR / OFF AIR (Grabación) -->
            <span class="status-badge @(Update.IsRecording ? "badge-onair" : "badge-offair")">
                @(Update.IsRecording ? "ON AIR" : "OFF AIR")
            </span>
            
            <!-- Badge STREAMING (Streaming) -->
            <span class="status-badge @(Update.IsStreaming ? "badge-streaming" : "badge-nostream")" title="URL: @Update.StreamUrl">
                WEB
            </span>
        </div>
    </div>

    <div class="meters-container">
        <div class="meter-row">
            <span class="meter-label">L</span>
            <div class="meter-track">
                <div class="meter-fill" style="clip-path: inset(0 @($"{100 - (Update.LeftLevel * 100):0.##}%") 0 0)"></div>
                <div class="meter-shine"></div>
                <div class="meter-grid"></div>
            </div>
        </div>
        <div class="meter-row">
            <span class="meter-label">R</span>
            <div class="meter-track">
                <div class="meter-fill" style="clip-path: inset(0 @($"{100 - (Update.RightLevel * 100):0.##}%") 0 0)"></div>
                <div class="meter-shine"></div>
                <div class="meter-grid"></div>
            </div>
        </div>
    </div>

    <div class="station-footer">
        <div class="footer-info">
            <span class="timestamp">@Update.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
        </div>
        
        <div class="custom-player">
            @if (Update.IsStreaming && !string.IsNullOrEmpty(Update.StreamUrl))
            {
                <div class="player-controls">
                    <button class="ctrl-btn @(IsPlaying ? "active" : "")" @onclick="TogglePlay" title="@(IsPlaying ? "Detener" : "Reproducir")">
                        @(IsPlaying ? "■" : "▶")
                    </button>
                    
                    @if (IsPlaying)
                    {
                        <button class="ctrl-btn mute-btn" @onclick="ToggleMute" title="@(IsMuted ? "Activar Sonido" : "Silenciar")">
                            @(IsMuted ? "🔇" : "🔊")
                        </button>
                    }
                </div>
                
                <audio @ref="audioElement" autoplay="@IsPlaying" muted="@IsMuted" style="display:none">
                    <source src="@Update.StreamUrl" type="audio/mpeg">
                </audio>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public StationStatusUpdate Update { get; set; } = new();
    private bool IsPlaying = false;
    private bool IsMuted = false;
    private ElementReference audioElement;

    private void TogglePlay()
    {
        IsPlaying = !IsPlaying;
        if (!IsPlaying) IsMuted = false;
    }

    private void ToggleMute()
    {
        IsMuted = !IsMuted;
    }
}