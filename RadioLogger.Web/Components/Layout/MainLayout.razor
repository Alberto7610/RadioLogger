@inherits LayoutComponentBase
@using RadioLogger.Web.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject MonitoringService Monitoring
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject AuthService AuthSvc
@implements IDisposable

@if (!_authChecked)
{
    <div style="width:100vw;height:100vh;background:#060810;display:flex;align-items:center;justify-content:center;">
        <div style="color:#45536a;font-family:'JetBrains Mono',monospace;font-size:12px;">Cargando...</div>
    </div>
    return;
}

<div class="sidebar">
    <div class="logo">
        <div class="logo-bars">
            <span></span><span></span><span></span><span></span><span></span>
        </div>
        <div class="logo-info">
            <div class="logo-name">RADIO<span style="color:var(--blue)">LOGGER</span></div>
            <div class="logo-ver">ENTERPRISE V2.0</div>
        </div>
    </div>

    <div class="nav-scroll">
        <div class="nav-sec">Principal</div>
        <NavLink class="nav-item" href="dashboard" Match="NavLinkMatch.All">
            <span class="nav-ico">📊</span>
            <span>Dashboard</span>
            <span class="nav-badge nb-blu">LIVE</span>
        </NavLink>
        <NavLink class="nav-item" href="estaciones">
            <span class="nav-ico">📡</span>
            <span>Estaciones</span>
        </NavLink>
        <NavLink class="nav-item" href="historial">
            <span class="nav-ico">📋</span>
            <span>Incidentes</span>
            <span class="nav-badge nb-red">@Monitoring.GetActiveIncidentsCount()</span>
        </NavLink>

        <NavLink class="nav-item" href="logs">
            <span class="nav-ico">🖥️</span>
            <span>Logs</span>
        </NavLink>

        <div class="nav-sec">Administración</div>
        @if (_userRole == "Administrador" || _userRole == "Supervisor")
        {
            <NavLink class="nav-item" href="licencias">
                <span class="nav-ico">🔑</span>
                <span>Licencias</span>
            </NavLink>
        }
        <NavLink class="nav-item" href="configuracion">
            <span class="nav-ico">⚙️</span>
            <span>Configuración</span>
        </NavLink>
        @if (_userRole == "Administrador")
        {
            <NavLink class="nav-item" href="usuarios">
                <span class="nav-ico">👤</span>
                <span>Usuarios</span>
            </NavLink>
            <NavLink class="nav-item" href="auditoria">
                <span class="nav-ico">📜</span>
                <span>Auditoría</span>
            </NavLink>
        }
    </div>

    <div class="sidebar-footer">
        <div class="user-card" @onclick="DoLogout" style="cursor:pointer" title="Cerrar sesión">
            <div class="avatar">@_userInitials</div>
            <div class="user-info">
                <div class="u-name">@_userDisplay</div>
                <div class="u-role">@_userRole.ToUpper()</div>
            </div>
            <div class="u-dot"></div>
        </div>
    </div>
</div>

<main class="main">
    <header class="topbar">
        <div class="topbar-title">MONITOR DE EMISORAS <span>CENTRAL DE CONTROL</span></div>
        
        <div class="pill">
            <div class="dot g"></div>
            <span>INTERNET OK</span>
        </div>
        <div class="pill">
            <div class="dot @(Monitoring.IsDatabaseHealthy ? "g" : "r")"></div>
            <span>SQL: @(Monitoring.IsDatabaseHealthy ? "ONLINE" : "OFFLINE")</span>
        </div>
        <div class="pill">
            <div class="dot @(Monitoring.GetActiveStations().Any(s => (DateTime.UtcNow - s.Timestamp).TotalSeconds < 15) ? "g" : "y")"></div>
            <span>WPF: @(Monitoring.GetActiveStations().Any(s => (DateTime.UtcNow - s.Timestamp).TotalSeconds < 15) ? "CONECTADO" : "SIN DATOS")</span>
        </div>
        
        <div class="clock">@DateTime.Now.ToString("HH:mm:ss")</div>
    </header>

    <div class="page active">
        @Body
    </div>
</main>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private System.Threading.Timer? _timer;
    private string _userDisplay = "";
    private string _userRole = "";
    private string _userInitials = "";
    private bool _authChecked;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                var user = authState.User;

                if (user.Identity == null || !user.Identity.IsAuthenticated)
                {
                    Nav.NavigateTo("/", true);
                    return;
                }

                _userDisplay = user.FindFirst("DisplayName")?.Value ?? user.Identity.Name ?? "";
                _userRole = user.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Operador";
                var initials = _userDisplay.Split(' ', StringSplitOptions.RemoveEmptyEntries)
                    .Where(w => w.Length > 0).Take(2).Select(w => w[0]);
                _userInitials = string.Join("", initials).ToUpperInvariant();
                if (_userInitials.Length == 0) _userInitials = "U";
                _authChecked = true;

                var msToNextSecond = 1000 - DateTime.Now.Millisecond;
                _timer = new System.Threading.Timer(_ =>
                {
                    InvokeAsync(StateHasChanged);
                }, null, msToNextSecond, 1000);

                StateHasChanged();
            }
            catch
            {
                // ProtectedSessionStorage no disponible aún — redirigir a login
                Nav.NavigateTo("/", true);
            }
        }
    }

    private async Task DoLogout()
    {
        var username = _userDisplay;
        await AuthSvc.LogActionAsync(username, "LOGOUT", "Cierre de sesión");
        var customAuth = (CustomAuthStateProvider)AuthStateProvider;
        await customAuth.LogoutAsync();
        Nav.NavigateTo("/", true);
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }
}
