@page "/"
@using RadioLogger.Shared.Models
@using RadioLogger.Web.Services
@using RadioLogger.Web.Components
@inject MonitoringService Monitoring
@implements IDisposable

<div class="content">
    <!-- Row: Stats -->
    <div class="stats-row">
        @{
            var allStations = Monitoring.GetActiveStations();
            var onlineCount = allStations.Count(s => (DateTime.UtcNow - s.Timestamp).TotalSeconds < 15);
            var disconnectedCount = allStations.Count(s => (DateTime.UtcNow - s.Timestamp).TotalSeconds >= 15);
            var silenceCount = allStations.Count(s => s.IsSilence && (DateTime.UtcNow - s.Timestamp).TotalSeconds < 15);
            var alertCount = Monitoring.GetActiveIncidentsCount() + disconnectedCount;
            var recordingCount = allStations.Count(s => s.IsRecording && (DateTime.UtcNow - s.Timestamp).TotalSeconds < 15);
            var streamingCount = allStations.Count(s => s.IsStreaming && (DateTime.UtcNow - s.Timestamp).TotalSeconds < 15);
            var deactivatedCount = Monitoring.GetRegisteredStations().Count(r => !r.Activa);
        }
        <div class="stat sg">
            <div class="stat-lbl">Online</div>
            <div class="stat-num ng">@onlineCount</div>
            <div class="stat-sub">EQUIPOS ACTIVOS</div>
        </div>
        <div class="stat sr">
            <div class="stat-lbl">Silence</div>
            <div class="stat-num nr">@silenceCount</div>
            <div class="stat-sub">DETECCIONES DE SILENCIO</div>
        </div>
        <div class="stat sa @(alertCount > 0 ? "stat-alert" : "")">
            <div class="stat-lbl">Alerts</div>
            <div class="stat-num na">@alertCount</div>
            <div class="stat-sub">INCIDENTES EN CURSO</div>
        </div>
        <div class="stat sb">
            <div class="stat-lbl">Record</div>
            <div class="stat-num nb">@recordingCount</div>
            <div class="stat-sub">GRABANDO A DISCO</div>
        </div>
        <div class="stat sc2">
            <div class="stat-lbl">Stream</div>
            <div class="stat-num nc">@streamingCount</div>
            <div class="stat-sub">BROADCAST WEB</div>
        </div>
    </div>

    <!-- Ticker: Alertas críticas -->
    @if (allStations.Any(s => s.IsSilence || (DateTime.UtcNow - s.Timestamp).TotalSeconds > 15))
    {
        <div class="ticker">
            <div class="ticker-lbl">ALERTAS</div>
            <div class="ticker-track">
                <div class="ticker-txt">
                    @foreach (var s in allStations.Where(s => s.IsSilence && (DateTime.UtcNow - s.Timestamp).TotalSeconds < 15))
                    {
                        <span>🚨 SILENCIO DETECTADO: @s.StationName (@s.MachineId) &nbsp;&nbsp; | &nbsp;&nbsp; </span>
                    }
                    @foreach (var s in allStations.Where(s => (DateTime.UtcNow - s.Timestamp).TotalSeconds >= 15))
                    {
                        <span style="color:var(--amber)">⚠️ EQUIPO DESCONECTADO: @s.StationName (@s.MachineId) &nbsp;&nbsp; | &nbsp;&nbsp; </span>
                    }
                </div>
            </div>
        </div>
    }

    <!-- Main Grid -->
    <div class="main-grid">
        <!-- Panel de Estaciones -->
        <div class="panel">
            <div class="panel-hdr">
                <div class="panel-title">ESTACIONES REGISTRADAS</div>
                <div class="tabs">
                    <div class="tab @(CurrentFilter == "ALL" ? "active" : "")" @onclick='() => SetFilter("ALL")'>
                        TODAS <span class="tab-count">@allStations.Count</span>
                    </div>
                    <div class="tab @(CurrentFilter == "ONLINE" ? "active" : "")" @onclick='() => SetFilter("ONLINE")'>
                        EN LÍNEA <span class="tab-count">@onlineCount</span>
                    </div>
                    <div class="tab @(CurrentFilter == "DISCONNECTED" ? "active" : "")" @onclick='() => SetFilter("DISCONNECTED")'>
                        DESCONECTADAS <span class="tab-count">@disconnectedCount</span>
                    </div>
                    <div class="tab @(CurrentFilter == "ERROR" ? "active" : "")" @onclick='() => SetFilter("ERROR")'>
                        ERRORES <span class="tab-count">@silenceCount</span>
                    </div>
                    @if (deactivatedCount > 0)
                    {
                        <div class="tab @(CurrentFilter == "DEACTIVATED" ? "active" : "")" @onclick='() => SetFilter("DEACTIVATED")'>
                            DESACTIVADAS <span class="tab-count">@deactivatedCount</span>
                        </div>
                    }
                </div>
                <input type="text" class="search" placeholder="BUSCAR ESTACIÓN..." @bind="SearchTerm" @bind:event="oninput">
            </div>

            <div class="st-scroll">
                @if (CurrentFilter == "DEACTIVATED")
                {
                    @foreach (var group in GetDeactivatedStations().GroupBy(s => s.MachineId))
                    {
                        <div class="grp grp-deactivated">
                            <div class="grp-hdr">
                                <span class="grp-tog">▼</span>
                                <span class="grp-name">EQUIPO: @group.Key</span>
                                <span class="grp-cnt">@group.Count()</span>
                                <span class="grp-deact">DESACTIVADAS</span>
                            </div>
                            <div class="st-grid">
                                @foreach (var station in group)
                                {
                                    <div class="deactivated-card">
                                        <div class="deact-name">@(!string.IsNullOrEmpty(station.Siglas) ? station.Siglas : station.StationName)</div>
                                        <div class="deact-hw">@station.HardwareName</div>
                                        <div class="deact-info">
                                            @if (!string.IsNullOrEmpty(station.Frecuencia))
                                            {
                                                <span>@station.Frecuencia @station.Banda</span>
                                            }
                                            @if (!string.IsNullOrEmpty(station.Plaza))
                                            {
                                                <span> — @station.Plaza</span>
                                            }
                                        </div>
                                        <button class="deact-btn" @onclick="() => ReactivateStation(station)">REACTIVAR</button>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    @foreach (var group in GetFilteredStations().GroupBy(s => s.MachineId))
                    {
                        <div class="grp">
                            <div class="grp-hdr">
                                <span class="grp-tog">▼</span>
                                <span class="grp-name">EQUIPO: @group.Key</span>
                                <span class="grp-cnt">@group.Count()</span>
                                @{
                                    var okCount = group.Count(s => !s.IsSilence && (DateTime.UtcNow - s.Timestamp).TotalSeconds < 15);
                                }
                                <span class="grp-on">● @okCount OK</span>
                            </div>
                            <div class="st-grid">
                                @foreach (var station in group)
                                {
                                    <div @onclick="() => OpenModal(station)" style="cursor:pointer">
                                        <StationCard @key="@($"{station.MachineId}:{station.StationName}")" Update="station" />
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

<!-- Modal de control remoto -->
<StationModal Station="ModalStation" IsVisible="IsModalOpen" OnClose="CloseModal" />

@code {
    private string CurrentFilter = "ALL";
    private string SearchTerm = "";
    private StationStatusUpdate? ModalStation;
    private bool IsModalOpen = false;

    protected override void OnInitialized()
    {
        Monitoring.OnUpdated += OnMonitoringUpdate;
    }

    private async void OnMonitoringUpdate()
    {
        await InvokeAsync(StateHasChanged);
    }

    private void SetFilter(string filter) => CurrentFilter = filter;

    private IEnumerable<StationStatusUpdate> GetFilteredStations()
    {
        var stations = Monitoring.GetActiveStations();

        if (!string.IsNullOrWhiteSpace(SearchTerm))
        {
            stations = stations.Where(s => s.StationName.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase)
                                       || s.MachineId.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase)).ToList();
        }

        return CurrentFilter switch
        {
            "ONLINE" => stations.Where(s => (DateTime.UtcNow - s.Timestamp).TotalSeconds < 15),
            "DISCONNECTED" => stations.Where(s => (DateTime.UtcNow - s.Timestamp).TotalSeconds >= 15),
            "ERROR" => stations.Where(s => s.IsSilence || (DateTime.UtcNow - s.Timestamp).TotalSeconds >= 15),
            _ => stations
        };
    }

    private IEnumerable<RegisteredStation> GetDeactivatedStations()
    {
        var stations = Monitoring.GetRegisteredStations().Where(r => !r.Activa);

        if (!string.IsNullOrWhiteSpace(SearchTerm))
        {
            stations = stations.Where(s => s.StationName.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase)
                                       || s.MachineId.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase));
        }

        return stations;
    }

    private async Task ReactivateStation(RegisteredStation station)
    {
        await Monitoring.SetStationActive(station.Id, true);
    }

    private void OpenModal(StationStatusUpdate station)
    {
        ModalStation = station;
        IsModalOpen = true;
    }

    private void CloseModal()
    {
        IsModalOpen = false;
    }

    public void Dispose()
    {
        Monitoring.OnUpdated -= OnMonitoringUpdate;
    }
}
