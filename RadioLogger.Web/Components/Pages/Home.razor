@page "/"
@rendermode InteractiveServer
@using RadioLogger.Shared.Models
@using RadioLogger.Web.Services
@using RadioLogger.Web.Components
@inject MonitoringService Monitoring
@implements IDisposable

<PageTitle>Dashboard - RadioLogger</PageTitle>

<div class="dashboard-container">
    <header class="dashboard-header">
        <div class="header-left">
            <h1 class="main-title">MONITOREO DE EMISORAS</h1>
            <span class="online-count">@Monitoring.GetActiveStations().Count Estaciones Activas</span>
        </div>
        
        <div class="header-right">
            <!-- Indicador de Base de Datos -->
            <div class="db-status @(Monitoring.IsDatabaseHealthy ? "db-ok" : "db-error")">
                <span class="db-dot"></span>
                <span class="db-label">@(Monitoring.IsDatabaseHealthy ? "SQL: ONLINE" : "SQL: OFFLINE")</span>
            </div>

            <div class="connection-status @(IsConnected ? "connected" : "disconnected")">
                @(IsConnected ? "● LIVE" : "○ RECONNECTING...")
            </div>
            
            <div class="alert-toggle" @onclick="ToggleAudioAlert">
                <span class="icon">@(IsAudioEnabled ? "🔊" : "🔇")</span>
                <span class="label">Alertas de Audio</span>
            </div>
        </div>
    </header>

    @if (Monitoring.GetActiveStations().Count == 0)
    {
        <div class="empty-state">
            <div class="empty-icon">📻</div>
            <h2>Esperando datos de la consola...</h2>
            <p>Asegúrate de que RadioLogger esté abierto y con SignalR habilitado.</p>
        </div>
    }
    else
    {
        @foreach (var group in Monitoring.GetActiveStations().GroupBy(s => s.MachineId))
        {
            <div class="machine-section">
                <h2 class="machine-title">💻 SERVIDOR: @group.Key</h2>
                <div class="stations-grid">
                    @foreach (var station in group)
                    {
                        <StationCard @key="@($"{station.MachineId}:{station.StationName}")" Update="station" />
                    }
                </div>
            </div>
        }
    }
</div>

@code {
    private bool IsAudioEnabled = false;
    private bool IsConnected = true; // In Blazor Server, the service is local, so it's always "connected" to the data

    protected override void OnInitialized()
    {
        Monitoring.OnUpdated += OnMonitoringUpdate;
    }

    private async void OnMonitoringUpdate()
    {
        await InvokeAsync(StateHasChanged);
    }

    private void ToggleAudioAlert()
    {
        IsAudioEnabled = !IsAudioEnabled;
    }

    public void Dispose()
    {
        Monitoring.OnUpdated -= OnMonitoringUpdate;
    }
}

<style>
    .machine-section {
        margin-bottom: 40px;
    }

    .machine-title {
        color: #888;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 15px;
        border-left: 3px solid #00aabb;
        padding-left: 10px;
    }

    .dashboard-container {
        padding: 20px;
        min-height: 100vh;
        background: #121212;
    }

    .dashboard-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        padding-bottom: 15px;
        border-bottom: 1px solid #333;
    }

    .main-title {
        color: #eee;
        font-size: 1.5rem;
        font-weight: 300;
        margin: 0;
        letter-spacing: 2px;
    }

    .online-count {
        color: #00aabb;
        font-size: 0.8rem;
        font-weight: bold;
    }

    .header-right {
        display: flex;
        align-items: center;
        gap: 20px;
    }

    /* DB STATUS NEON STYLES */
    .db-status {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 5px 12px;
        border-radius: 4px;
        background: #1a1a1a;
        font-size: 0.75rem;
        font-weight: bold;
        border: 1px solid #333;
    }

    .db-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }

    .db-ok {
        border-color: #00ff00;
        color: #00ff00;
        box-shadow: 0 0 10px rgba(0, 255, 0, 0.2);
    }
    .db-ok .db-dot { background: #00ff00; box-shadow: 0 0 8px #00ff00; }

    .db-error {
        border-color: #ff4444;
        color: #ff4444;
        box-shadow: 0 0 10px rgba(255, 68, 68, 0.2);
        animation: db-blink 1s infinite;
    }
    .db-error .db-dot { background: #ff4444; box-shadow: 0 0 8px #ff4444; }

    @@keyframes db-blink {
        0% { opacity: 1; }
        50% { opacity: 0.5; }
        100% { opacity: 1; }
    }

    .connection-status {
        font-size: 0.8rem;
        font-weight: bold;
        padding: 5px 12px;
        border-radius: 20px;
        background: #222;
    }

    .connection-status.connected { color: #00ff00; }
    .connection-status.disconnected { color: #ff4444; }

    .alert-toggle {
        cursor: pointer;
        background: #222;
        padding: 8px 15px;
        border-radius: 4px;
        display: flex;
        align-items: center;
        gap: 10px;
        transition: all 0.2s;
    }

    .alert-toggle:hover {
        background: #333;
    }

    .alert-toggle .label {
        font-size: 0.8rem;
        color: #aaa;
    }

    .stations-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 25px;
        align-items: flex-start;
        justify-content: flex-start;
    }

    .empty-state {
        text-align: center;
        margin-top: 100px;
        color: #555;
    }

    .empty-icon {
        font-size: 4rem;
        margin-bottom: 20px;
        opacity: 0.3;
    }
</style>
