@page "/history"
@using Microsoft.EntityFrameworkCore
@using RadioLogger.Shared.Models
@using RadioLogger.Web.Data
@inject RadioDbContext Db

<PageTitle>Historial de Incidentes - CloudRadioLogger</PageTitle>

<div class="history-container">
    <header class="history-header">
        <h1 class="main-title">HISTORIAL DE INCIDENTES</h1>
        <div class="header-actions">
            <a href="/" class="btn-back">← VOLVER AL DASHBOARD</a>
        </div>
    </header>

    <div class="stats-summary">
        <div class="stat-box">
            <span class="stat-value">@totalIncidents</span>
            <span class="stat-label">Total Incidentes</span>
        </div>
        <div class="stat-box">
            <span class="stat-value text-red">@activeIncidents</span>
            <span class="stat-label">Activos Ahora</span>
        </div>
    </div>

    <div class="table-container">
        <table class="history-table">
            <thead>
                <tr>
                    <th>ESTACIÓN</th>
                    <th>EVENTO</th>
                    <th>INICIO</th>
                    <th>FIN</th>
                    <th>DURACIÓN</th>
                    <th>ESTADO</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in incidents)
                {
                    <tr class="@(log.IsResolved ? "" : "row-active")">
                        <td><span class="station-name">@log.StationName</span></td>
                        <td><span class="event-type">@log.EventType</span></td>
                        <td>@log.StartTime.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</td>
                        <td>@(log.EndTime?.ToLocalTime().ToString("HH:mm:ss") ?? "--")</td>
                        <td>@(log.DurationSeconds.HasValue ? FormatDuration(log.DurationSeconds.Value) : "--")</td>
                        <td>
                            <span class="status-pill @(log.IsResolved ? "pill-resolved" : "pill-active")">
                                @(log.IsResolved ? "RESUELTO" : "ACTIVO")
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<IncidentLog> incidents = new();
    private int totalIncidents;
    private int activeIncidents;

    protected override async Task OnInitializedAsync()
    {
        incidents = await Db.Incidents
            .OrderByDescending(i => i.StartTime)
            .Take(50)
            .ToListAsync();

        totalIncidents = await Db.Incidents.CountAsync();
        activeIncidents = await Db.Incidents.CountAsync(i => !i.IsResolved);
    }

    private string FormatDuration(double seconds)
    {
        var t = TimeSpan.FromSeconds(seconds);
        if (t.TotalMinutes < 1) return $"{t.Seconds}s";
        return $"{(int)t.TotalMinutes}m {t.Seconds}s";
    }
}

<style>
    .history-container {
        padding: 20px;
        min-height: 100vh;
        background: #121212;
        color: #eee;
    }

    .history-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        border-bottom: 1px solid #333;
        padding-bottom: 15px;
    }

    .main-title {
        font-size: 1.5rem;
        font-weight: 300;
        letter-spacing: 2px;
        margin: 0;
    }

    .btn-back {
        text-decoration: none;
        color: #00aabb;
        font-size: 0.8rem;
        font-weight: bold;
        padding: 8px 15px;
        border: 1px solid #00aabb;
        border-radius: 4px;
        transition: all 0.2s;
    }

    .btn-back:hover {
        background: #00aabb;
        color: white;
    }

    .stats-summary {
        display: flex;
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-box {
        background: #1e1e1e;
        padding: 15px 25px;
        border-radius: 8px;
        border: 1px solid #333;
        text-align: center;
        min-width: 150px;
    }

    .stat-value {
        display: block;
        font-size: 1.8rem;
        font-weight: bold;
        color: #00aabb;
    }

    .stat-value.text-red { color: #ff4444; }

    .stat-label {
        font-size: 0.7rem;
        color: #666;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .table-container {
        background: #1e1e1e;
        border-radius: 8px;
        border: 1px solid #333;
        overflow: hidden;
    }

    .history-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.9rem;
    }

    .history-table th {
        background: #252526;
        text-align: left;
        padding: 12px 20px;
        color: #666;
        font-weight: bold;
        font-size: 0.7rem;
        text-transform: uppercase;
    }

    .history-table td {
        padding: 12px 20px;
        border-bottom: 1px solid #252526;
    }

    .row-active {
        background: rgba(255, 68, 68, 0.05);
    }

    .station-name {
        color: #00aabb;
        font-weight: bold;
    }

    .event-type {
        background: #333;
        padding: 2px 6px;
        border-radius: 3px;
        font-size: 0.7rem;
    }

    .status-pill {
        font-size: 0.7rem;
        font-weight: bold;
        padding: 3px 8px;
        border-radius: 10px;
    }

    .pill-resolved { background: #007e33; color: white; }
    .pill-active { background: #ff4444; color: white; animation: blink 1s infinite; }

    @@keyframes blink {
        0% { opacity: 1; }
        50% { opacity: 0.5; }
        100% { opacity: 1; }
    }
</style>
